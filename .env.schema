# @currentEnv=$APP_ENV
# @defaultSensitive=false
# @defaultRequired=false
# ---

# Runtime environment for local examples and generated apps.
# @type=enum(development, staging, production)
APP_ENV=development

# Optional model override in provider/name form. Telegram co-founder defaults to Pi-managed openai-codex/gpt-5.4-mini.
# @type=string
HEYPI_MODEL=

# Discord application client ID used by invite helpers.
# @type=string
DISCORD_CLIENT_ID=

# Local-only flag that enables Telegram co-founder mutating tools without a trusted Telegram user allowlist.
# @type=boolean @sensitive
HEYPI_LOCAL_DEV_MUTATIONS=false

# Telegram bot token for the Telegram co-founder example.
# @type=string @sensitive
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram chat allowlist for the Telegram co-founder example.
# @type=string
HEYPI_TELEGRAM_CHATS=

# Comma-separated Telegram user allowlist for the Telegram co-founder example.
# @type=string
HEYPI_TELEGRAM_USERS=

# Comma-separated roots where Telegram co-founder engineering handoffs may target local repos.
# @type=string
HEYPI_TRUSTED_WORKSPACE_ROOTS=

# Optional runtime workspace root for Telegram co-founder core tools. Use a concrete repo path for local dev.
# @type=string
HEYPI_RUNTIME_ROOT=

# Runtime used when HEYPI_RUNTIME_ROOT is set.
# @type=enum(just-bash, guarded-bash, host-bash)
HEYPI_RUNTIME_NAME=guarded-bash

# Local port for the webhook example HTTP listener.
# @type=number
HEYPI_WEBHOOK_PORT=3000

# Optional admin UI URL used by CLI helpers.
# @type=url
HEYPI_ADMIN_URL=

# Optional admin secret used by CLI helpers.
# @type=string @sensitive
HEYPI_ADMIN_SECRET=

# Optional explicit state root used by CLI helpers.
# @type=string
HEYPI_STATE_ROOT=

# Optional document converter command for attachments.
# @type=string
HEYPI_DOCUMENT_CONVERTER=heypi-convert-document

# SQLite path used by Drizzle configuration.
# @type=string
HEYPI_DB_PATH=

# Test-only secret used by runtime redaction coverage.
# @type=string @sensitive
HEYPI_SECRET_TEST=

# Package manager user agent read by create-heypi.
# @type=string
npm_config_user_agent=

# Package manager initial working directory read by create-heypi.
# @type=string
INIT_CWD=

# Terminal color controls used by test and CLI output.
# @type=string
FORCE_COLOR=

# Terminal color opt-out used by test and CLI output.
# @type=string
NO_COLOR=

# Process PATH forwarded to document conversion helpers.
# @type=string
PATH=
