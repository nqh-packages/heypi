{
	"name": "@hunvreus/heypi",
	"version": "0.1.2",
	"description": "Chat agents for your team, with approvals and sandboxed tools.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"heypi": "bin/heypi",
		"heypi-convert-document": "bin/heypi-convert-document"
	},
	"exports": {
		".": {
			"development": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./adapter": {
			"development": "./src/adapter/index.ts",
			"types": "./dist/adapter/index.d.ts",
			"import": "./dist/adapter/index.js"
		},
		"./attachments": {
			"development": "./src/attachments/index.ts",
			"types": "./dist/attachments/index.d.ts",
			"import": "./dist/attachments/index.js"
		},
		"./runtime": {
			"development": "./src/runtime/public.ts",
			"types": "./dist/runtime/public.d.ts",
			"import": "./dist/runtime/public.js"
		},
		"./store": {
			"development": "./src/store/index.ts",
			"types": "./dist/store/index.d.ts",
			"import": "./dist/store/index.js"
		}
	},
	"files": [
		"bin/heypi",
		"bin/heypi-convert-document",
		"bin/heypi-convert-document.py",
		"dist",
		"docs",
		"ARCHITECTURE.md",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"engines": {
		"node": ">=22"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hunvreus/heypi.git",
		"directory": "packages/heypi"
	},
	"bugs": {
		"url": "https://github.com/hunvreus/heypi/issues"
	},
	"homepage": "https://heypi.dev",
	"keywords": [
		"agent",
		"ai",
		"chatbot",
		"discord",
		"pi",
		"slack",
		"telegram",
		"tools"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "rm -rf dist && pnpm run build:secret-css && tsc -p tsconfig.build.json && mkdir -p dist/drizzle dist/core/assets && cp drizzle/*.sql dist/drizzle/ && cp src/core/assets/secret.css dist/core/assets/secret.css && pnpm run build:admin-assets",
		"build:admin-assets": "mkdir -p dist/admin && cp -R src/admin/assets dist/admin/",
		"build:admin-css": "mkdir -p src/admin/assets && tailwindcss -i src/admin/style.css -o src/admin/assets/admin.css --minify && cp node_modules/basecoat-css/dist/js/all.min.js src/admin/assets/basecoat.all.min.js",
		"build:secret-css": "mkdir -p src/core/assets && tailwindcss -i src/core/secret.css -o src/core/assets/secret.css --minify",
		"dev:admin-css": "mkdir -p src/admin/assets && tailwindcss -i src/admin/style.css -o src/admin/assets/admin.css --watch",
		"prepack": "pnpm run build",
		"pack:dry": "npm pack --dry-run",
		"publish:dry": "npm publish --dry-run --access public",
		"heypi": "tsx --conditions development src/cli.ts",
		"check": "biome check .",
		"fmt": "biome format --write .",
		"typecheck": "pnpm run build && tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"test": "pnpm run build && node --import tsx --test tests/*.test.ts"
	},
	"dependencies": {
		"@earendil-works/pi-coding-agent": "^0.75.5",
		"@libsql/client": "^0.17.3",
		"@sinclair/typebox": "^0.34.49",
		"@slack/bolt": "^4.7.2",
		"cac": "^7.0.0",
		"croner": "^10.0.1",
		"discord.js": "^14.26.4",
		"drizzle-orm": "^0.45.2",
		"just-bash": "^3.0.1",
		"unbash": "3.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@tailwindcss/cli": "^4.3.0",
		"@types/node": "^25.9.1",
		"basecoat-css": "0.3.11",
		"drizzle-kit": "^0.31.10",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3"
	},
	"packageManager": "pnpm@10.17.1"
}
